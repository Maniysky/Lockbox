# ─── App target ───────────────────────────────────────────────────────────────
# URL of the running Next.js app (DEV or UAT environment)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# ─── Test user credentials ────────────────────────────────────────────────────
# These users must exist in the test database with the correct roles/permissions.
# Seed them using scripts/add-permission-tables.sql + scripts/20260402_roles_accountant_ar_assistant.sql
#
# Credentials provider in src/auth.ts accepts email + password for non-prod builds.

TEST_ACCOUNTANT_EMAIL=accountant@test.local
TEST_ACCOUNTANT_PASSWORD=test-password

TEST_AR_ASSISTANT_EMAIL=arassistant@test.local
TEST_AR_ASSISTANT_PASSWORD=test-password

TEST_SECURITY_ADMIN_EMAIL=securityadmin@test.local
TEST_SECURITY_ADMIN_PASSWORD=test-password

TEST_APP_ADMIN_EMAIL=appadmin@test.local
TEST_APP_ADMIN_PASSWORD=test-password

# ─── LockBox automated processing ─────────────────────────────────────────────
# Must match what the running app has configured (from src/server/config/env.ts)
# Used when calling POST /api/lockbox/process (automated job endpoint)
TEST_LOCKBOX_API_KEY=change-me-in-production

# ─── Known test data IDs ──────────────────────────────────────────────────────
# Seeded account IDs in the test DB — these must be stable across test runs.
# See scripts/20260402_suspense_accounts_seed.sql for the seed values.
TEST_GLOBAL_SUSPENSE_ACCOUNT_ID=1
TEST_CHECK_SUSPENSE_ACCOUNT_ID=2
TEST_ACH_SUSPENSE_ACCOUNT_ID=3
