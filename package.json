{
  "name": "lockbox-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E test framework for BOA LockBox Processing & Cash Application",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui:chromium",
    "test:api": "playwright test --project=api",
    "test:rbac": "playwright test e2e/tests/rbac/",
    "test:lockbox": "playwright test e2e/tests/lockbox/",
    "test:admin": "playwright test e2e/tests/admin/",
    "test:e2e": "playwright test e2e/tests/e2e/",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report playwright-report",
    "setup": "playwright test --project=setup"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.0",
    "typescript": "^5.4.0"
  }
}
