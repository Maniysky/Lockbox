{
  "name": "lockbox-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E test framework for BOA LockBox Processing & Cash Application",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui:chromium",
    "test:api": "playwright test --project=api",
    "test:rbac": "playwright test tests/rbac/",
    "test:lockbox": "playwright test tests/lockbox/",
    "test:admin": "playwright test tests/admin/",
    "test:e2e": "playwright test tests/e2e/",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report playwright-report",
    "report:custom": "node utils/reporter/open-custom-report.cjs",
    "setup": "playwright test --project=setup"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "dotenv": "^17.4.1",
    "typescript": "^5.9.3"
  }
}
